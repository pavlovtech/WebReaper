<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>preview</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!-- Tier-2 implementation classes are public only because the
         extension method and tests bind to them; not the satellite's
         documented contract. CS1591 silenced for those. -->
    <NoWarn>$(NoWarn);CS1591</NoWarn>

    <PackageId>WebReaper.AI</PackageId>
    <Title>WebReaper.AI</Title>
    <Description>LLM-backed IContentExtractor for WebReaper, bound to Microsoft.Extensions.AI.Abstractions (IChatClient). Bring your own model: OpenAI, Anthropic, Ollama, anything implementing IChatClient. Adds ScraperEngineBuilder.WithLlmExtractor. Satellite package (ADR-0009) so the WebReaper core stays dependency-light and AOT-clean.</Description>
    <!-- ADR-0017: relicensed to MIT to remove funnel-adoption friction. -->
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>scraper, crawler, llm, ai, extraction, openai, anthropic</PackageTags>
    <PackageIcon>logo.png</PackageIcon>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageReleaseNotes>10.0.1: NuGet metadata polish. Adds PackageReadmeFile so the README shows on the package page. Removes em-dashes from Description and release notes. No code changes. 10.0.0: initial release. LLM-backed IContentExtractor satellite (ADR-0044) bound to Microsoft.Extensions.AI.Abstractions (IChatClient). Bring your own model: OpenAI, Anthropic, Ollama, anything implementing IChatClient. Ships LlmContentExtractor (Markdown pre-clean by default, deterministic Temperature=0, MaxTokens=4096), a Schema-to-JSON-Schema bridge, and ScraperEngineBuilder.WithLlmExtractor. Also ships LlmSelectorRepairer + WithLlmSelfHealing for the SelfHealingContentExtractor (ADR-0047): LLM proposes selectors on a fold failure, deterministic re-run validates, per-crawl cache persists the patch. New satellite package per ADR-0009: the consumer's IChatClient makes the LLM call, so the satellite quarantines AI deps off the dependency-light, Native-AOT-clean core. Requires WebReaper 10.0.0.</PackageReleaseNotes>

    <!-- ADR-0009 quarantine: the consumer's chat client makes the AOT
         call; the satellite isn't AOT-required so the core's clean
         AOT story is unaffected. -->
  </PropertyGroup>

  <ItemGroup>
    <!-- 10.3.0 (stable, not preview): the highest abstractions that the latest
         stable Anthropic.SDK (5.10.0) is binary-compatible with — 10.6.0 changed
         HostedMcpServerTool and breaks Anthropic.SDK at runtime. Floor, not pin:
         consumers not using Anthropic.SDK can still resolve higher. -->
    <PackageReference Include="Microsoft.Extensions.AI.Abstractions" Version="10.3.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\WebReaper\WebReaper.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="..\WebReaper\logo.png" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="WebReaper.AI.Tests" />
  </ItemGroup>

</Project>
