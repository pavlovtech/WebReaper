<?xml version="1.0" encoding="utf-8"?>
<!-- The global config's private ETPNuget feed 401s and aborts AOT-pack
     restore; nuget.org has the ILCompiler packs. Scoped to this project. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
